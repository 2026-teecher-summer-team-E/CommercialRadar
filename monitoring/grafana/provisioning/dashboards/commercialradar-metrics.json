{
  "id": null,
  "uid": "commercialradar-metrics",
  "title": "CommercialRadar — Metrics (RPS·TPS·CPU)",
  "tags": ["commercialradar", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RPS (요청/초)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 응답 지연",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[$__rate_interval])) by (le))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx 에러율 (요청/초)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB 커넥션 수",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_database_numbackends{datname=\"commercialradar\"})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RPS (상태코드별)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(http_requests_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "응답 지연 (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "서버 CPU 사용률 (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "서버 메모리 사용량",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Postgres TPS (commit + rollback)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=\"commercialradar\"}[$__rate_interval])) + sum(rate(pg_stat_database_xact_rollback{datname=\"commercialradar\"}[$__rate_interval]))",
          "legendFormat": "tps"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Postgres 데드락 (초당)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 70 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_deadlocks{datname=\"commercialradar\"}[$__rate_interval]))",
          "legendFormat": "deadlocks/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "엔드포인트별 RPS (어디서 많이 들어오나)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total[$__rate_interval]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "엔드포인트별 p95 지연 (어느 게 느린가 = 개선 대상)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "엔드포인트 요약 — 개선 우선순위 (p95 느린 순)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total[$__range]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[$__range])))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total{status=~\"5..\"}[$__range]))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "handler", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true },
            "renameByName": { "handler": "엔드포인트", "Value #A": "요청/초", "Value #B": "p95(초)", "Value #C": "5xx/초" }
          }
        },
        { "id": "sortBy", "options": { "fields": "", "sort": [ { "field": "p95(초)", "desc": true } ] } }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95(초)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.8 } ] } }
            ]
          },
          { "matcher": { "id": "byName", "options": "요청/초" }, "properties": [ { "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 2 } ] },
          { "matcher": { "id": "byName", "options": "5xx/초" }, "properties": [ { "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 3 } ] }
        ]
      }
    }
  ]
}
