# --- Database ---
# postgres 서비스 계정. DATABASE_URL이 아래 값들을 참조한다.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=commercialradar
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# --- 실행 환경 ---
# dev로 두면 인증(JWT)·웹훅 서명 검증을 건너뜀(로컬 Swagger 테스트용). 프로덕션은 반드시 prod.
# 주의: prod가 아니면 인증이 전면 무력화된다.
ENV=prod

# --- CORS ---
# 허용할 프론트 origin(콤마 구분). 프로덕션은 실제 프론트 도메인을 명시한다.
# 미설정 시 기본값은 로컬 개발용(localhost:5173 등). 와일드카드('*')는 사용 불가.
CORS_ORIGINS=https://your-frontend-domain.com

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_live_xxxxxx
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_xxxxxx

# --- Cache ---
REDIS_URL=redis://localhost:6379

# --- 배포(docker-compose.prod.yml / Caddy HTTPS) ---
# 도메인이 있으면 자동 HTTPS. 없으면 :80 (HTTP만, 임시).
SITE_ADDRESS=api.your-domain.com

# --- DB 백업(scripts/backup-db.sh → S3) ---
BACKUP_S3_BUCKET=

# --- 모니터링(docker-compose.monitoring.yml) ---
# Grafana 관리자 비밀번호. 미설정 시 'admin'(반드시 변경).
GRAFANA_ADMIN_PASSWORD=

# --- 외부 데이터 API ---
SEOUL_API_KEY=<서울 열린데이터광장 API 키>
# R-ONE 부동산통계 인증키 (한국부동산원 https://www.reb.or.kr/r-one)
REB_API_KEY=<R-ONE 부동산통계 인증키>

# --- Admin ---
ADMIN_KEY=<어드민 엔드포인트 인증 키>
